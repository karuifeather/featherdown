{
  "name": "featherdown",
  "version": "0.3.0",
  "description": "Markdown-to-HTML pipeline with sanitization, diagnostics, and optional Node Mermaid rendering.",
  "type": "module",
  "sideEffects": [
    "*.css",
    "styles/**/*.css"
  ],
  "files": [
    "dist",
    "styles.css",
    "styles"
  ],
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    },
    "./node": {
      "types": "./dist/node.d.ts",
      "import": "./dist/node.js",
      "default": "./dist/node.js"
    },
    "./advanced": {
      "types": "./dist/advanced.d.ts",
      "import": "./dist/advanced.js",
      "default": "./dist/advanced.js"
    },
    "./styles.css": "./styles.css",
    "./styles/base.css": "./styles/base.css",
    "./styles/katex.css": "./styles/katex.css",
    "./styles/code.css": "./styles/code.css",
    "./styles/highlight.css": "./styles/highlight.css",
    "./package.json": "./package.json"
  },
  "scripts": {
    "build": "tsup",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint .",
    "typecheck": "tsc --noEmit",
    "test:exports": "npm run build && node ./test/exports.smoke.mjs",
    "verify-release-version": "node ./scripts/verify-release-version.mjs",
    "prepublishOnly": "npm run lint && npm run typecheck && npm test && npm run test:exports",
    "site:install": "npm install --prefix site",
    "site:dev": "npm run dev --prefix site",
    "site:build": "npm run build && npm run build --prefix site",
    "site:preview": "npm run preview --prefix site"
  },
  "keywords": [
    "markdown",
    "remark",
    "rehype",
    "html",
    "sanitization",
    "katex",
    "mermaid",
    "publishing"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/karuifeather/featherdown.git"
  },
  "bugs": {
    "url": "https://github.com/karuifeather/featherdown/issues"
  },
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "engines": {
    "node": ">=18"
  },
  "peerDependencies": {
    "playwright": "^1.59.1"
  },
  "peerDependenciesMeta": {
    "playwright": {
      "optional": true
    }
  },
  "devDependencies": {
    "@eslint/js": "^9.18.0",
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^22.19.17",
    "eslint": "^9.18.0",
    "playwright": "^1.59.1",
    "tsup": "^8.3.5",
    "typescript": "^5.7.3",
    "typescript-eslint": "^8.21.0",
    "vitest": "^3.0.5"
  },
  "dependencies": {
    "hast-util-to-text": "^4.0.2",
    "highlight.js": "^11.11.0",
    "js-yaml": "^4.1.1",
    "katex": "^0.16.0",
    "lowlight": "^3.3.0",
    "rehype-autolink-headings": "^7.1.0",
    "rehype-highlight": "^7.0.2",
    "rehype-katex": "^7.0.1",
    "rehype-mermaid": "^3.0.0",
    "rehype-raw": "^7.0.0",
    "rehype-sanitize": "^6.0.0",
    "rehype-slug": "^6.0.0",
    "rehype-stringify": "^10.0.1",
    "remark-directive": "^4.0.0",
    "remark-gfm": "^4.0.1",
    "remark-math": "^6.0.0",
    "remark-parse": "^11.0.0",
    "remark-rehype": "^11.1.2",
    "unified": "^11.0.5",
    "unist-util-visit": "^5.1.0"
  }
}
